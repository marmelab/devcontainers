{
  "name": "Marmelab DevContainers",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/devcontainers",
  "workspaceMount": "source=${localWorkspaceFolder},target=${containerWorkspaceFolder},type=bind,consistency=cached",
  "postCreateCommand": "zsh ./.devcontainer/post-create.sh",
  "features": {
    "./claude-code": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/common-utils": {
      "installZsh": true,
      "installOhMyZsh": true,
      "installOhMyZshConfig": true,
      "configureZshAsDefaultShell": true
    }
  },
  "mounts": [
    {
      "type": "volume",
      "source": "${devcontainerId}-node-modules",
      "target": "/workspaces/devcontainers/node_modules"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": ["oxc.oxc-vscode"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
